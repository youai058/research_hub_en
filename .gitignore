/.local/
# Binary caches (regenerated by paper-summarize pipeline)
papers/digest/**/.pdf_cache/
papers/marp-summary/**/.figure_cache/

# Gemini digest markdown — Stage 1 cache of paper-summarize, fully regenerable
papers/digest/**/*.digest.md

# Binary RAG / KG stores (rebuilt via /research-index, /research-kg build)
papers/vector_db/chroma/
papers/vector_db/*.sqlite
papers/vector_db/*.sqlite-*
papers/vector_db/rejected.jsonl

# Old locations (keep until confirmed migrated; safe to remove later)
papers/rag/
papers/kg/

# Runtime loop state and backups
research/loop_state.json
research/loop_state.*.bak.json

# Regenerable experiment outputs
results_*/
experiments/*/runs/
experiments/*/logs/

# Python
__pycache__/
*.pyc
*.pyo

# Secrets
.env
.env.*
