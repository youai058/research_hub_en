{
  "env": {
    "HF_HOME": "/home/irteam/.cache/huggingface",
    "TOKENIZERS_PARALLELISM": "false",
    "CLAUDE_CODE_DISABLE_ADAPTIVE_THINKING": "1"
  },
  "permissions": {
    "allow": [],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(rm -rf /*)",
      "Bash(git push --force*)",
      "Bash(git reset --hard*)",
      "Bash(rm -rf *papers/rag*)",
      "Bash(rm -rf *papers/kg*)",
      "Bash(rm -rf *research/*)",
      "Bash(rm -rf *experiments/*)"
    ],
    "defaultMode": "bypassPermissions"
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/home1/irteam/sw/research_hub_en/.claude/hooks/session_start.sh"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "/home1/irteam/sw/research_hub_en/.claude/hooks/inject_lessons.sh full"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/home1/irteam/sw/research_hub_en/.claude/hooks/inject_lessons.sh titles"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/home1/irteam/sw/research_hub_en/.claude/hooks/phase_advance_check.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "/home1/irteam/sw/research_hub_en/.claude/hooks/mark_indices_stale.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "/home1/irteam/sw/research_hub_en/.claude/hooks/protect_chroma.sh"
          },
          {
            "type": "command",
            "command": "/home1/irteam/sw/research_hub_en/.claude/hooks/protect_kg.sh"
          },
          {
            "type": "command",
            "command": "/home1/irteam/sw/research_hub_en/.claude/hooks/guard_empty_rag.sh"
          }
        ]
      },
      {
        "matcher": "Write|Edit|MultiEdit|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "/home1/irteam/sw/research_hub_en/.claude/hooks/protect_external_paths.sh"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "python3 /home1/irteam/sw/research_hub_en/.claude/scripts/loop_state.py status --short"
  },
  "skipDangerousModePermissionPrompt": true,
  "enabledPlugins": {
    "superpowers@claude-plugins-official": true
  }
}
